<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003" author="match-poll-consumer">
        <comment>Create matches table to store game polls</comment>
        <createTable schemaName="match_day" tableName="matches">
            <column name="id" type="SERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="poll_message_id" type="TEXT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="group_name" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="creator" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="poll_name" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="match_date" type="TIMESTAMPTZ"/>
            <column name="options" type="TEXT[]">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
